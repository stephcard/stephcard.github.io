{
  "name": "stephany-cardet-folio",
  "scripts": {
    "format": "prettier --write **/*.{js,s?css,yml} !dist",
    "dev": "cross-env NODE_ENV=development run-p -l dev:*",
    "dev:webpack": "webpack --config webpack.dev.js ",
    "dev:eleventy": "ELEVENTY_ENV=development eleventy --serve",
    "build": "cross-env NODE_ENV=production run-s -l build:*",
    "build:clean": "rimraf dist",
    "build:webpack": "webpack --config webpack.prod.js",
    "build:eleventy": "ELEVENTY_ENV=production eleventy",
    "analyze": "run-s prod analyze:*",
    "analyze:js": "source-map-explorer dist/**/*.js dist/**/*.js.map"
  },
  "devDependencies": {
    "@11ty/eleventy": "^0.11.0",
    "@babel/cli": "^7.8.4",
    "@babel/core": "^7.9.6",
    "@babel/preset-env": "^7.9.6",
    "babel-loader": "^8.1.0",
    "babel-plugin-transform-es2015-modules-commonjs-simple": "^6.7.4",
    "core-js": "^3.6.5",
    "cross-env": "^7.0.2",
    "css-loader": "^3.5.3",
    "file-loader": "^6.0.0",
    "html-minifier": "^4.0.0",
    "html-webpack-plugin": "^4.3.0",
    "js-yaml": "^3.14.0",
    "mini-css-extract-plugin": "^0.9.0",
    "node-sass": "^4.14.1",
    "npm-run-all": "^4.1.5",
    "optimize-css-assets-webpack-plugin": "^5.0.3",
    "postcss-loader": "^3.0.0",
    "postcss-preset-env": "^6.7.0",
    "prettier": "^2.0.5",
    "rimraf": "^3.0.2",
    "sass-loader": "^8.0.2",
    "source-map-explorer": "^2.4.2",
    "webpack": "^4.43.0",
    "webpack-cli": "^3.3.11",
    "webpack-merge": "^4.2.2"
  },
  "dependencies": {
    "@carbon/charts": "^0.32.3",
    "@carbon/ibmdotcom-styles": "^1.9.0",
    "@carbon/ibmdotcom-vanilla": "^0.7.0",
    "@carbon/ibmdotcom-web-components": "^0.2.0",
    "@carbon/type": "^10.13.0",
    "carbon-components": "^10.13.0",
    "clipboard": "^2.0.6",
    "d3": "^5.16.0",
    "jquery": "^3.5.1",
    "lit-css": "^0.1.3",
    "lit-element": "^2.3.1",
    "lit-html": "^1.2.1",
    "moment": "^2.27.0",
    "scrollmagic": "^2.0.7",
    "scrollreveal": "^4.0.6",
    "smoothscroll-polyfill": "^0.4.4",
    "vanilla-lazyload": "^16.1.0"
  }
}
